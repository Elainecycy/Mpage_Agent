      { "url": "https://cdn.test.bank.com/c02/sec1.png", "name": "sec1.png", "note": "章节背景" },
      { "url": "https://cdn.test.bank.com/c02/flash_bg.png", "name": "flash_bg.png", "note": "秒杀卡片背景" },
