    "focus": "最基本格式与单卡片",
    "user_prompt": "做一个简单的优惠活动页。头图主标题\"限时特惠\"。一个章节标题\"今日推荐\"，放一段文字卡片写\"全场八折，仅限今天\"。",
    "asset_manifest": [
      { "url": "https://cdn.test.bank.com/c01/kv.png", "name": "kv.png", "note": "头图" }
    ],
    "expect": {
      "min_chapters": 1, "max_chapters": 1,
      "card_slots": [ { "chapter": 0, "card": 0, "accept": ["TextCard"] } ],
      "expected_assets": ["https://cdn.test.bank.com/c01/kv.png"],
      "must_contain_texts": ["限时特惠", "全场八折，仅限今天"]
    }
  },
  {
