# Agent 服务环境变量示例。复制为 .env 后按需填写（.env 已被 .gitignore 忽略，勿提交密钥）。

# —— LLM 网关（OpenAI 兼容接口）——
MPAGE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MPAGE_LLM_API_KEY=          # 必填：网关密钥，禁止写进代码库
MPAGE_LLM_MODEL=qwen-plus
MPAGE_LLM_TEMPERATURE=0.2
MPAGE_LLM_JSON_MODE=false
MPAGE_LLM_TIMEOUT_S=60
MPAGE_LLM_MAX_RETRIES=1

# —— 存储 ——
MPAGE_DATABASE_URL=sqlite:///./mpage_agent.db

# —— 服务 ——
MPAGE_APP_NAME=mpage-agent
MPAGE_LOG_LEVEL=INFO
